# ─────────────────────────────────────────────
#  COMALAS — Variables de entorno
#  Copia este archivo como .env y llena los valores
#  NUNCA subas el .env real a Git
# ─────────────────────────────────────────────

# Base de datos
DB_USER=comalas_user
DB_PASSWORD=cambia_esta_password_segura
DB_NAME=comalas

# Message Broker RabbitMQ
MQ_USER=comalas_mq
MQ_PASSWORD=cambia_esta_password_mq

# JWT — genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui

# Twilio WhatsApp (equipo de automatización lo configura)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=tu_auth_token_de_twilio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
